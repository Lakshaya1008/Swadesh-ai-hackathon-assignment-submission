# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Default Docker PostgreSQL: postgres:password on localhost:5432
DATABASE_URL=postgresql://postgres:password@localhost:5432/my-better-t-app

# CORS origin for the frontend (where requests come from)
# Set to your frontend URL in production
CORS_ORIGIN=http://localhost:3001

# Node environment
# Options: development, production, test
NODE_ENV=development

# Deepgram API Key for audio transcription
# Get free key at: https://console.deepgram.com
# Leave empty to test the system without transcription
DEEPGRAM_API_KEY=your_deepgram_api_key_here
